// This is your Prisma schema file.
// Learn more about Prisma schema syntax at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  ownerId        String?         @db.Uuid
  settings       Json?
  users          User[]
  customers      Customer[]
  inventoryItems InventoryItem[]
  bookings       Booking[]
  bookingItems   BookingItem[]
  payments       Payment[]
  expenses       Expense[]
  deliveries     Delivery[]
  damageReports  DamageReport[]
  activityLogs   ActivityLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([slug])
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  password       String
  name           String?
  role           UserRole       @default(STAFF)
  status         UserStatus     @default(ACTIVE)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId String?        @db.Uuid
  bookings       Booking[]      @relation("UserCreatedBookings")
  payments       Payment[]      @relation("PaymentProcessedBy")
  expenses       Expense[]      @relation("ExpenseCreatedBy")
  damageReports  DamageReport[]
  activityLogs   ActivityLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([email])
  @@index([organizationId])
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @db.Uuid
  firstName      String
  lastName       String
  email          String?
  phone          String?
  company        String?
  address        String?
  notes          String?
  bookings       Booking[]
  deliveries     Delivery[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model InventoryItem {
  id                String          @id @default(uuid()) @db.Uuid
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId    String          @db.Uuid
  sku               String
  name              String
  description       String?
  category          String?
  unitPrice         Decimal         @db.Decimal(12, 2)
  costPrice         Decimal         @db.Decimal(12, 2)
  damageFee         Decimal         @default(0) @db.Decimal(12, 2)
  imageUrl          String?
  totalQuantity     Int             @default(0)
  availableQuantity Int             @default(0)
  rentedQuantity    Int             @default(0)
  damagedQuantity   Int             @default(0)
  minimumThreshold  Int             @default(0)
  status            InventoryStatus @default(AVAILABLE)
  bookingItems      BookingItem[]
  damageReports     DamageReport[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([organizationId, sku])
  @@index([sku])
  @@index([organizationId])
}

model Booking {
  id              String         @id @default(uuid()) @db.Uuid
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String         @db.Uuid
  bookingNumber   String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId      String         @db.Uuid
  eventDate       DateTime
  deliveryDate    DateTime?
  returnDate      DateTime?
  status          BookingStatus  @default(PENDING)
  notes           String?
  deliveryFee     Decimal        @default(0) @db.Decimal(12, 2)
  setupFee        Decimal        @default(0) @db.Decimal(12, 2)
  discount        Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  depositAmount   Decimal        @default(0) @db.Decimal(12, 2)
  depositPaid     Decimal        @default(0) @db.Decimal(12, 2)
  depositRefunded Decimal        @default(0) @db.Decimal(12, 2)
  depositStatus   DepositStatus  @default(PENDING)
  refundStatus    RefundStatus   @default(NONE)
  balanceDue      Decimal        @default(0) @db.Decimal(12, 2)
  createdBy       User?          @relation("UserCreatedBookings", fields: [createdById], references: [id], onDelete: SetNull)
  createdById     String?        @db.Uuid
  bookingItems    BookingItem[]
  payments        Payment[]
  expenses        Expense[]
  delivery        Delivery?
  damageReports   DamageReport[]
  activityLogs    ActivityLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([organizationId, bookingNumber])
  @@index([bookingNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([eventDate, status])
}

model BookingItem {
  id               String        @id @default(uuid()) @db.Uuid
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String        @db.Uuid
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId        String        @db.Uuid
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  inventoryItemId  String        @db.Uuid
  quantity         Int           @default(1)
  unitPrice        Decimal       @db.Decimal(12, 2)
  discount         Decimal       @default(0) @db.Decimal(12, 2)
  totalPrice       Decimal       @db.Decimal(12, 2)
  returnedQuantity Int           @default(0)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([bookingId])
  @@index([inventoryItemId])
  @@index([organizationId])
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId       String        @db.Uuid
  booking              Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId            String?       @db.Uuid
  amount               Decimal       @db.Decimal(12, 2)
  method               PaymentMethod
  type                 PaymentType   @default(RENTAL)
  status               PaymentStatus @default(PENDING)
  transactionReference String?
  processedBy          User?         @relation("PaymentProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  processedById        String?       @db.Uuid
  processedAt          DateTime?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([organizationId, transactionReference])
  @@index([bookingId])
  @@index([organizationId])
  @@index([status])
  @@index([type])
}

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String          @db.Uuid
  category       ExpenseCategory
  amount         Decimal         @db.Decimal(12, 2)
  incurredAt     DateTime
  vendor         String?
  receiptUrl     String?
  booking        Booking?        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId      String?         @db.Uuid
  createdBy      User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById    String?         @db.Uuid
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([incurredAt])
  @@index([organizationId])
  @@index([category])
}

model Delivery {
  id             String         @id @default(uuid()) @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String         @db.Uuid
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId      String         @unique @db.Uuid
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId     String         @db.Uuid
  status         DeliveryStatus @default(SCHEDULED)
  scheduledAt    DateTime
  deliveredAt    DateTime?
  pickupAt       DateTime?
  driver         String?
  vehicle        String?
  address        String
  instructions   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([bookingId])
  @@index([customerId])
  @@index([organizationId])
  @@index([scheduledAt])
}

model DamageReport {
  id              String         @id @default(uuid()) @db.Uuid
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String         @db.Uuid
  booking         Booking?       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId       String?        @db.Uuid
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  inventoryItemId String         @db.Uuid
  reportedBy      User?          @relation(fields: [reportedById], references: [id], onDelete: SetNull)
  reportedById    String?        @db.Uuid
  reportDate      DateTime       @default(now())
  quantity        Int            @default(1)
  severity        DamageSeverity @default(MINOR)
  notes           String?
  resolved        Boolean        @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([inventoryItemId])
  @@index([bookingId])
  @@index([resolved])
}

model ActivityLog {
  id             String        @id @default(uuid()) @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String        @db.Uuid
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         String?       @db.Uuid
  booking        Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId      String?       @db.Uuid
  action         String
  entity         String
  entityId       String?
  details        String?
  level          ActivityLevel @default(INFO)
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([bookingId])
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DepositStatus {
  PENDING
  PAID
  HELD
  REFUNDED
  PARTIALLY_REFUNDED
  FORFEITED
}

enum RefundStatus {
  NONE
  REQUESTED
  APPROVED
  PARTIAL
  FORFEITED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  MOBILE_WALLET
}

enum PaymentType {
  RENTAL
  SECURITY_DEPOSIT
  REFUND
}

enum InventoryStatus {
  AVAILABLE
  MAINTENANCE
  OUT_OF_STOCK
  RETIRED
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  OPERATIONS
  MAINTENANCE
  PROCUREMENT
  MARKETING
  OTHER
}

enum DamageSeverity {
  MINOR
  MODERATE
  SEVERE
}

enum ActivityLevel {
  INFO
  WARNING
  ERROR
}
